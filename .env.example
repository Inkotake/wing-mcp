# WING MCP Server Configuration
# Copy this to .env and adjust for your setup

# Operation mode: read_only | rehearsal_safe | maintenance | developer_raw
WING_MODE=rehearsal_safe

# Set to 1 during live performance (disables raw tools, extra safety)
WING_LIVE_MODE=0

# Driver: fake (dev/testing) | native (libwing via Rust sidecar) | osc (UDP fallback)
WING_DRIVER=fake

# Enable raw OSC/Native protocol tools (developer mode only)
WING_ENABLE_RAW=0

# WING console IP for native/osc drivers
WING_HOST=192.168.1.62

# Audit log file path
WING_AUDIT_PATH=./data/audit.jsonl
