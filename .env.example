# wing-mcp MCP Server Configuration
# Copy to .env and adjust for your setup

# Driver: fake (dev/testing) | osc (UDP 2223, experimental) | native (libwing, stub)
WING_DRIVER=fake

# WING console IP (for osc/native drivers)
WING_HOST=192.168.1.62

# Operation mode: read_only | rehearsal_safe | maintenance | developer_raw
WING_MODE=rehearsal_safe

# Set to 1 during live performance
WING_LIVE_MODE=0

# Enable raw OSC/Native tools (developer_raw mode only)
WING_ENABLE_RAW=0
# Required for raw tools: must explicitly unlock
WING_RAW_UNLOCK=

# Audit log directory (daily JSONL files)
WING_AUDIT_DIR=./data/audit

# Hardware tests (default disabled — requires real WING)
WING_HARDWARE_TEST=0

# Allow unverified OSC paths (dev only — NOT for production)
WING_ALLOW_UNVERIFIED_OSC_PATHS=0

# Note: Transport is stdio only. Streamable HTTP is planned, not yet implemented.
# Note: Native/libwing runtime is a stub. Only propmap (parameter catalog) is integrated.
